## 复制为 .env 后按需修改（不要把 .env 提交到 Git）

## ─── App / PHP ───────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true

# JWT 配置（生产环境请使用强随机字符串）
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRE=86400

# 日志级别
LOG_LEVEL=debug

## ─── Database (MySQL) ────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=yii_link
DB_CHARSET=utf8mb4
DB_USER=yii_link
DB_PASS=yii_link_secret
MYSQL_ROOT_PASSWORD=root_secret

## ─── Redis 缓存和限流 ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=2.0

## ─── Ports ───────────────────────────────────────────────────
NGINX_HTTP_PORT=8000
MYSQL_PORT=3306
REDIS_PORT=6379

## ─── Container names (可选) ───────────────────────────────────
BACKEND_CONTAINER_NAME=yii-link-backend
NGINX_CONTAINER_NAME=yii-link-nginx
MYSQL_CONTAINER_NAME=yii-link-mysql
REDIS_CONTAINER_NAME=yii-link-redis

## ─── Images (可选) ────────────────────────────────────────────
MYSQL_IMAGE=mysql:8.0
REDIS_IMAGE=redis:7-alpine

## ─── 健康检查和重启策略 ────────────────────────────────────────
BACKEND_RESTART_POLICY=unless-stopped
NGINX_RESTART_POLICY=unless-stopped
MYSQL_RESTART_POLICY=unless-stopped
REDIS_RESTART_POLICY=unless-stopped

MYSQL_HEALTHCHECK_INTERVAL=10s
MYSQL_HEALTHCHECK_TIMEOUT=5s
MYSQL_HEALTHCHECK_RETRIES=5
MYSQL_HEALTHCHECK_START_PERIOD=30s

