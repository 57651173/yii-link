# ─── 应用配置 ──────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true

# ─── 数据库配置 ────────────────────────────────────────────────
# Docker 环境：host 使用服务名 mysql（而非 127.0.0.1）
DB_DSN=mysql:host=mysql;dbname=yii_link;charset=utf8mb4
DB_USER=yii_link
DB_PASS=yii_link_secret

# 本地开发（非 Docker）：取消注释下方，注释上方
# DB_DSN=mysql:host=127.0.0.1;dbname=yii_link;charset=utf8mb4
# DB_USER=root
# DB_PASS=

# ─── JWT 配置 ──────────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRE=86400
